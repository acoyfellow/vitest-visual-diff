{
  "name": "vitest-visual-diff",
  "version": "0.0.1",
  "private": true,
  "description": "Compare two live elements through structure, computed style, pixels, and accessibility in Vitest Browser Mode.",
  "type": "module",
  "sideEffects": [
    "./src/index.ts"
  ],
  "packageManager": "bun@1.3.14",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/acoyfellow/vitest-visual-diff.git"
  },
  "homepage": "https://github.com/acoyfellow/vitest-visual-diff#readme",
  "bugs": {
    "url": "https://github.com/acoyfellow/vitest-visual-diff/issues"
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "keywords": [
    "vitest",
    "vitest-plugin",
    "visual-regression",
    "visual-diff",
    "browser-mode",
    "custom-matcher",
    "pixelmatch",
    "accessibility"
  ],
  "peerDependencies": {
    "@vitest/browser": ">=4.0.0",
    "vitest": ">=4.0.0"
  },
  "scripts": {
    "check": "bun run format:check && bun run typecheck && bun run test && bun run test:webdriverio && bun run test:all-browsers",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:webdriverio": "vitest run --config vitest.config.webdriverio.ts",
    "test:all-browsers": "vitest run --config vitest.config.multibrowser.ts",
    "typecheck": "tsc --noEmit"
  },
  "license": "MIT",
  "devDependencies": {
    "@vitest/browser": "^4.1.10",
    "@vitest/browser-playwright": "^4.1.10",
    "@biomejs/biome": "^2.3.8",
    "@vitest/browser-webdriverio": "^4.1.10",
    "playwright": "^1.61.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "pixelmatch": "^7.2.0"
  }
}
